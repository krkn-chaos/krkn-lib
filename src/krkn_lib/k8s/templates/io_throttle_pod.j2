apiVersion: v1
kind: Pod
metadata:
  name: io-throttle-{{pod_suffix}}
spec:
  nodeName: {{nodename}}
  containers:
  - name: io-throttle
    image: {{image}}
    command: ["/bin/sh", "-c", "trap : TERM INT; sleep infinity & wait"]
    securityContext:
      privileged: true
    volumeMounts:
    - name: host-root
      mountPath: /host
  volumes:
  - name: host-root
    hostPath:
      path: /
  restartPolicy: Never
